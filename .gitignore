# =============================================================================
# ENTRUSTORY — MONOREPO .gitignore
# Covers: entrustory-web, entrustory-cli, supabase, root
# =============================================================================

# -----------------------------------------------------------------------------
# SECRETS & CREDENTIALS — NEVER COMMIT THESE
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.example.*
*.secret
secret*.txt
Secret*.txt
Acc*.txt
*.key
*.pem
*.p12
*.pfx

# -----------------------------------------------------------------------------
# NODE / NPM
# -----------------------------------------------------------------------------
node_modules/
jspm_packages/
web_modules/
bower_components/
.npm
.yarn-integrity
*.tgz
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# -----------------------------------------------------------------------------
# BUILD OUTPUTS
# -----------------------------------------------------------------------------
dist/
out/
build/Release
.next/
.nuxt/
.svelte-kit/
**/.vitepress/dist
**/.vitepress/cache
.docusaurus/
.serverless/
.fusebox/
.dynamodb/
.firebase/

# -----------------------------------------------------------------------------
# LOGS
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# -----------------------------------------------------------------------------
# RUNTIME / TEMP
# -----------------------------------------------------------------------------
pids/
*.pid
*.seed
*.pid.lock
.cache/
.parcel-cache/
.temp/
lib-cov/
coverage/
*.lcov
.nyc_output/
.grunt/
.lock-wscript
.node_repl_history
.tern-port
.vscode-test

# -----------------------------------------------------------------------------
# TYPESCRIPT
# -----------------------------------------------------------------------------
*.tsbuildinfo
*.tsbuildinfo.*

# -----------------------------------------------------------------------------
# VITE
# -----------------------------------------------------------------------------
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# -----------------------------------------------------------------------------
# SUPABASE
# -----------------------------------------------------------------------------
.supabase/
supabase/.branches/
supabase/.temp/

# -----------------------------------------------------------------------------
# PYTHON (BlackSignal / any local scripts)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.env/
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# -----------------------------------------------------------------------------
# EDITOR & OS
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# ENTRUSTORY-CLI SPECIFIC
# -----------------------------------------------------------------------------
entrustory-cli/.env
entrustory-cli/secret*.txt
entrustory-cli/*.secret

# -----------------------------------------------------------------------------
# CODE REVIEW / AI TOOLING (don't commit graph DBs)
# -----------------------------------------------------------------------------
.code-review-graph/
.claude/
.opencode.json
.mcp.json

# -----------------------------------------------------------------------------
# MISC
# -----------------------------------------------------------------------------
*.lcov
.eslintcache
.stylelintcache
